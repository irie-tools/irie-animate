{
  "name": "irie-animate",
  "version": "0.1.0",
  "private": true,
  "description": "Config-driven app for turning video clips into scroll-driven animated websites.",
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0",
    "lint": "next lint",
    "typecheck": "next typegen && tsc --noEmit",
    "pipeline": "node pipeline/build-frames.mjs",
    "pipeline:demo": "node pipeline/build-frames.mjs --brand irie-demo --demo",
    "verify": "npm run typecheck && npm run build",
    "deploy": "vercel"
  },
  "dependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "lucide-react": "^0.468.0",
    "next": "^15.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.5",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.2",
    "playwright": "^1.61.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
